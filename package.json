{
  "name": "kioskids",
  "version": "1.0.0",
  "description": "Electron-based kiosk for children's play areas — offline-first time management",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "pnpm rebuild:electron && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm rebuild:electron && pnpm build && electron-builder",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "node scripts/rebuild-node.mjs",
    "pretest": "pnpm rebuild:node",
    "test": "vitest run",
    "posttest": "pnpm rebuild:electron",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "postinstall": "pnpm rebuild:electron"
  },
  "author": "Rafhael Marsigli",
  "license": "UNLICENSED",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "^10.0.0"
      }
    },
    "allowedDeprecatedVersions": {
      "boolean": "3.2.0",
      "glob": "7.2.3 || 10.5.0",
      "inflight": "1.0.6",
      "rimraf": "2.6.3",
      "prebuild-install": "7.1.3"
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-router": "^1.163.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "i18next": "^25.8.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}